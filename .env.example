# Copy this file to ".env" and fill in your values. ".env" is gitignored —
# never commit real keys. Shell variables override these (e.g. `PORT=3200 npm start`).

# --- Server ---
PORT=3100

# --- Stripe billing (optional) ---
# Without these the app runs in "dev mode" (upgrades apply instantly, no payment).
# Use TEST-mode values first (sk_test_..., test price IDs, 4242 4242 4242 4242).
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_WEBHOOK_SECRET=

# --- Owner accounts (optional) ---
# Comma-separated emails that always get the top (Team) plan for free.
# OWNER_EMAILS=you@example.com

# --- Reminders (optional) ---
# REMINDER_WEBHOOK_URL=https://ntfy.sh/your-topic
# REMINDER_ENABLED=1
