# Copy this file to ".env" and fill in your values. ".env" is gitignored —
# never commit real keys. Shell variables override these (e.g. `PORT=3200 npm start`).

# --- Server ---
PORT=3100

# --- Stripe billing (optional) ---
# Without these the app runs in "dev mode" (upgrades apply instantly, no payment).
# Use TEST-mode values first (sk_test_..., test price IDs, 4242 4242 4242 4242).
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
# Annual prices (optional) — set both to show the yearly billing toggle.
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_TEAM_ANNUAL=
STRIPE_WEBHOOK_SECRET=

# --- Owner accounts (optional) ---
# Comma-separated emails that always get the top (Team) plan for free.
# OWNER_EMAILS=you@example.com

# --- Email (optional) ---
# Sends password-reset + member-invite emails. Two ways to enable:
#  A) Resend (simplest) — set both. EMAIL_FROM must be on a domain you've
#     verified in Resend (or onboarding@resend.dev for testing to your own addr).
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=EchoDeck <hello@yourdomain.com>
#  B) Or your own relay that accepts {to,subject,text,html} as JSON.
# EMAIL_WEBHOOK_URL=https://your-relay.example/send
# With none set, email runs in dev mode (logs; API returns the reset link).

# --- Reminders (optional) ---
# REMINDER_WEBHOOK_URL=https://ntfy.sh/your-topic
# REMINDER_ENABLED=1

# --- AI card-back fill (optional) ---
# Set an Anthropic API key to enable the "AI fill" buttons (translation + notes).
# Unset → the feature is disabled and hidden in the UI.
# ANTHROPIC_API_KEY=sk-ant-...
# Model: defaults to the budget tier (claude-haiku-4-5-20251001) — card fills
# are short, structured completions, so this keeps API costs to ~$0.001/card.
# ANTHROPIC_MODEL is accepted as an alias for ECHODECK_LLM_MODEL.
# ECHODECK_LLM_MODEL=claude-haiku-4-5-20251001
# Cost backstops: per-call output token cap and per-workspace daily fill limit.
# ECHODECK_LLM_MAX_TOKENS=300
# ECHODECK_AI_DAILY_LIMIT=300

# --- Auto-transcription (optional) ---
# Speech-to-text endpoint. Receives {audioUrl}, returns {segments:[{start,end,text}]}
# or {text}. Point at a Whisper/Deepgram/AssemblyAI relay or self-hosted service.
# Unset → the "Transcribe" button is hidden.
# TRANSCRIBE_WEBHOOK_URL=https://your-stt-relay.example/transcribe

# --- URL / YouTube import ---
# Paste a YouTube link (pulls its captions) or a direct .srt/.vtt/.txt URL to
# fill the transcript box. Needs only outbound network, so it's ON by default.
# Set to 1 to disable the feature (and hide its UI).
# ECHODECK_IMPORT_DISABLED=1
# Optional: a Supadata API key makes YouTube caption import reliable from the
# server (YouTube blocks the free scrape from datacenter IPs). Get one at
# supadata.ai. Unset → free best-effort scrape.
# SUPADATA_API_KEY=

# --- Web Push (optional) ---
# Generate once: npx web-push generate-vapid-keys
# Unset → the "Enable notifications" button is hidden.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com

# --- Agent Arena model registry (optional) ---
# Point this at a JSON feed ({ "providers": { ... } }) to auto-add real future
# models to the arena. Unset → built-in catalog + a demo release simulation.
# ARENA_MODELS_URL=
# Demo release cadence in ms (how often a simulated new model appears).
# ARENA_RELEASE_INTERVAL_MS=90000

# --- Agent Arena live runs (optional, OFF by default) ---
# When ARENA_LIVE=1 AND a provider key is set, the arena calls real models for
# providers it has an adapter for; others stay simulated. Costs real tokens.
# ARENA_LIVE=1
# Anthropic reuses ANTHROPIC_API_KEY. Map arena model ids → real API strings:
# ARENA_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ARENA_ANTHROPIC_OPUS=
# ARENA_ANTHROPIC_SONNET=
# ARENA_ANTHROPIC_HAIKU=
