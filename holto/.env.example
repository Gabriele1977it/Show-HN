# ── HOLTO environment ───────────────────────────────────────────────────────
# Copy to `.env` and fill in. The API server and the monitor worker both read
# these. Never commit real secrets.

# Postgres connection string (required by api-server, monitor-worker, db).
DATABASE_URL=postgres://user:password@localhost:5432/holto

# HTTP port for the API server (hosts like Render inject this automatically).
PORT=5000

# Secret used to sign JWT session tokens (required in production).
SESSION_SECRET=change-me-to-a-long-random-string

# Gemini (Google AI Studio) — the primary, free-tier LLM for AI features
# (companion tone, document parsing). Get a key at aistudio.google.com.
GEMINI_API_KEY=
# Optional: pin a specific Gemini model (otherwise a free-tier fallback chain is
# used, e.g. gemini-2.5-flash → 2.0-flash → …).
GEMINI_MODEL=
# OpenAI — optional fallback only; unset by default to stay on the free tier.
OPENAI_API_KEY=

# Emails that always get owner access (Admin panel + Pro tier), comma-separated.
OWNER_EMAILS=

# AirLabs — live flight status data.
AIRLABS_API_KEY=
# Zyla — cost-of-living data for the Living tab (Zyla API Hub bearer key).
ZYLA_API_KEY=

# ── Transactional email (Resend) ─────────────────────────────────────────────
# Preferred sender for password-reset links etc. Free tier: 3,000 emails/month.
# Get a key at resend.com and verify your sending domain/subdomain.
RESEND_API_KEY=
# The verified "From" address (must be on your verified domain/subdomain).
EMAIL_FROM=HOLTO <hello@send.holtotravel.com>

# ── AwardWallet (loyalty auto-import) ────────────────────────────────────────
# Account Access API key (sent as the X-Authentication header). Free tier;
# see awardwallet.com/api/account. Leave blank to keep the feature hidden.
AWARDWALLET_API_KEY=
# The AwardWallet "connect" link users open to authorise HOLTO.
AWARDWALLET_CONNECT_URL=

# ── Proactive monitoring ─────────────────────────────────────────────────────
# Expo push access token (optional; raises push throughput / enables receipts).
EXPO_ACCESS_TOKEN=
# Poll interval for the monitor worker in milliseconds (default 900000 = 15 min).
MONITOR_POLL_MS=900000
# How long (ms) to cache a flight's status before re-querying AirLabs. Protects
# the AirLabs free-tier quota by de-duplicating lookups (default 300000 = 5 min).
FLIGHT_CACHE_TTL_MS=300000
# Outbound webhook that turns an alert POST into an email (Zapier/Make/Resend/
# Postmark relay). If unset, email-fallback alerts are logged to the console.
EMAIL_WEBHOOK_URL=

# ── Host / CORS ──────────────────────────────────────────────────────────────
# Public base URL of the deployed API (used for CORS + the Stripe webhook URL).
PUBLIC_URL=
APP_ORIGIN=
# Extra allowed CORS origins, comma-separated (optional).
ALLOWED_ORIGINS=

# ── Billing (optional) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
